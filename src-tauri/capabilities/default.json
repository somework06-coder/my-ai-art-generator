{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:allow-temp-write",
      "allow": [
        {
          "path": "$TEMP/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-temp-read",
      "allow": [
        {
          "path": "$TEMP/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-appdata-write",
      "allow": [
        {
          "path": "$APPDATA/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-appdata-read",
      "allow": [
        {
          "path": "$APPDATA/**"
        }
      ]
    },
    "shell:default",
    "os:default"
  ]
}